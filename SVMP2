def explain_confusion_matrix(cm):
    print("\n================ CONFUSION MATRIX EXPLANATION ================")
    print("Rows represent the actual true digit.")
    print("Columns represent the predicted digit.")
    print("Diagonal values are correct predictions.")
    print("Off-diagonal values are mistakes.\n")

    for cls in range(cm.shape[0]):
        correct = cm[cls, cls]
        total = np.sum(cm[cls])
        class_recall = correct / total if total != 0 else 0

        print(
            f"Digit {cls}: {correct}/{total} correctly classified "
            f"({class_recall:.2%})"
        )

        row = cm[cls].copy()
        row[cls] = 0

        most_confused_with = np.argmax(row)
        mistakes = row[most_confused_with]

        if mistakes > 0:
            print(
                f"  Most common mistake: actual {cls} predicted as "
                f"{most_confused_with} {mistakes} times."
            )
        else:
            print("  No mistakes for this digit.")


