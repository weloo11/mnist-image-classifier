# 12. Bias-variance analysis
# ============================================================

def bias_variance_analysis(
    X_train,
    y_train,
    X_val,
    y_val,
    lambda_values,
    base_config,
    n_classes=10
):
    analysis_results = []

    for lam in lambda_values:
        print("\n=================================================")
        print("Bias-Variance Test | Lambda =", lam)
        print("=================================================")

        model = MulticlassOVRSVMFromScratch(
            n_classes=n_classes,
            learning_rate=base_config["learning_rate"],
            lambda_param=lam,
            n_epochs=base_config["n_epochs"],
            batch_size=base_config["batch_size"],
            lr_decay=base_config["lr_decay"],
            patience=base_config["patience"],
            pos_weight_scale=base_config["pos_weight_scale"],
            verbose=False
        )

        model.fit(
            X_train,
            y_train,
            X_val=X_val,
            y_val=y_val
        )

        train_pred = model.predict(X_train)
        val_pred = model.predict(X_val)

        train_acc = accuracy_score_manual(y_train, train_pred)
        val_acc = accuracy_score_manual(y_val, val_pred)

        _, _, train_macro_f1 = macro_precision_recall_f1(
            y_train,
            train_pred,
            n_classes=n_classes
        )

        _, _, val_macro_f1 = macro_precision_recall_f1(
            y_val,
            val_pred,
            n_classes=n_classes
        )

        gap = train_macro_f1 - val_macro_f1

        if train_macro_f1 < 0.80 and val_macro_f1 < 0.80:
            diagnosis = "Underfitting"
        elif gap > 0.08:
            diagnosis = "Overfitting"
        else:
            diagnosis = "Good fit"

        analysis_results.append({
            "Lambda": lam,
            "Train Accuracy": train_acc,
            "Val Accuracy": val_acc,
            "Train Macro F1": train_macro_f1,
            "Val Macro F1": val_macro_f1,
            "Gap": gap,
            "Diagnosis": diagnosis
        })

        print("Train Macro F1:", train_macro_f1)
        print("Val Macro F1  :", val_macro_f1)
        print("Diagnosis     :", diagnosis)

        del model
        del train_pred
        del val_pred
        gc.collect()

    return pd.DataFrame(analysis_results)


