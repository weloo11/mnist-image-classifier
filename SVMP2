def load_mnist_multiclass():
    (x_train, y_train), (x_test, y_test) = mnist.load_data()

    x_train = x_train.astype(np.float32)
    x_test = x_test.astype(np.float32)

    print("Original train:", x_train.shape, y_train.shape)
    print("Original test :", x_test.shape, y_test.shape)

    return x_train, y_train, x_test, y_test


# ============================================================
# 2. Optional stratified subset
# ============================================================

def stratified_subset(X, y, size, random_state=42):
    np.random.seed(random_state)

    selected_indices = []
    classes = np.unique(y)

    per_class = size // len(classes)

    for cls in classes:
        cls_indices = np.where(y == cls)[0]
        np.random.shuffle(cls_indices)
        selected_indices.extend(cls_indices[:per_class])

    selected_indices = np.array(selected_indices)
    np.random.shuffle(selected_indices)

    return X[selected_indices], y[selected_indices]


# ============================================================
# 3. Stratified train/validation split
# ============================================================

def stratified_train_val_split_multiclass(
    X,
    y,
    val_ratio=0.15,
    random_state=42
):
    np.random.seed(random_state)

    train_indices = []
    val_indices = []

    classes = np.unique(y)

    for cls in classes:
        cls_indices = np.where(y == cls)[0]
        np.random.shuffle(cls_indices)

        val_size = int(len(cls_indices) * val_ratio)

        val_indices.extend(cls_indices[:val_size])
        train_indices.extend(cls_indices[val_size:])

    train_indices = np.array(train_indices)
    val_indices = np.array(val_indices)

    np.random.shuffle(train_indices)
    np.random.shuffle(val_indices)

    return (
        X[train_indices],
        y[train_indices],
        X[val_indices],
        y[val_indices]
    )


# ============================================================
# 4. Memory-safe CNN feature extraction
# ============================================================

def prepare_batch_for_mobilenet(batch, image_size=64):
    batch = batch[..., np.newaxis]
    batch = np.repeat(batch, 3, axis=-1)
    batch = tf.image.resize(batch, (image_size, image_size)).numpy()
    batch = preprocess_input(batch)

    return batch


def extract_features_in_batches(
    images,
    feature_extractor,
    image_size=64,
    prepare_batch_size=128,
    predict_batch_size=32
):
    feature_batches = []
    total = len(images)

    for start in range(0, total, prepare_batch_size):
        end = min(start + prepare_batch_size, total)

        batch = images[start:end]

        batch_prepared = prepare_batch_for_mobilenet(
            batch,
            image_size=image_size
        )

        batch_features = feature_extractor.predict(
            batch_prepared,
            batch_size=predict_batch_size,
            verbose=0
        )

        feature_batches.append(batch_features.astype(np.float32))

        print(f"Extracted CNN features: {end}/{total}")

        del batch
        del batch_prepared
        del batch_features
        gc.collect()

    return np.concatenate(feature_batches, axis=0).astype(np.float32)


def extract_cnn_features(
    x_train,
    x_val,
    x_test,
    image_size=64,
    prepare_batch_size=128,
    predict_batch_size=32
):
    print("\nLoading pretrained VGG16...")

    feature_extractor = VGG16(
        weights="imagenet",
        include_top=False,
        pooling="avg",
        input_shape=(image_size, image_size, 3)
    )

    feature_extractor.trainable = False

    print("\nExtracting train CNN features...")
    X_train = extract_features_in_batches(
        x_train,
        feature_extractor,
        image_size=image_size,
        prepare_batch_size=prepare_batch_size,
        predict_batch_size=predict_batch_size
    )

    print("\nExtracting validation CNN features...")
    X_val = extract_features_in_batches(
        x_val,
        feature_extractor,
        image_size=image_size,
        prepare_batch_size=prepare_batch_size,
        predict_batch_size=predict_batch_size
    )

    print("\nExtracting test CNN features...")
    X_test = extract_features_in_batches(
        x_test,
        feature_extractor,
        image_size=image_size,
        prepare_batch_size=prepare_batch_size,
        predict_batch_size=predict_batch_size
    )

    print("\nExtracted train features:", X_train.shape)
    print("Extracted val features  :", X_val.shape)
    print("Extracted test features :", X_test.shape)

    del feature_extractor
    gc.collect()

    return X_train, X_val, X_test





# ============================================================
# 5. Feature standardization
# ============================================================

def standardize_features(X_train, X_val, X_test):
    mean = np.mean(X_train, axis=0).astype(np.float32)
    std = np.std(X_train, axis=0).astype(np.float32)

    std[std == 0] = 1.0

    X_train_scaled = ((X_train - mean) / std).astype(np.float32)
    X_val_scaled = ((X_val - mean) / std).astype(np.float32)
    X_test_scaled = ((X_test - mean) / std).astype(np.float32)

    return X_train_scaled, X_val_scaled, X_test_scaled, mean, std


def standardize_train_val(X_train, X_val):
    mean = np.mean(X_train, axis=0).astype(np.float32)
    std = np.std(X_train, axis=0).astype(np.float32)

    std[std == 0] = 1.0

    X_train_scaled = ((X_train - mean) / std).astype(np.float32)
    X_val_scaled = ((X_val - mean) / std).astype(np.float32)

    return X_train_scaled, X_val_scaled


# ============================================================
# 6. Metrics from scratch
# ============================================================

def accuracy_score_manual(y_true, y_pred):
    return np.mean(y_true == y_pred)


def confusion_matrix_multiclass(y_true, y_pred, n_classes=10):
    cm = np.zeros((n_classes, n_classes), dtype=int)

    for true_label, pred_label in zip(y_true, y_pred):
        cm[int(true_label), int(pred_label)] += 1

    return cm


def precision_recall_f1_per_class(y_true, y_pred, n_classes=10):
    cm = confusion_matrix_multiclass(y_true, y_pred, n_classes)

    precision_list = []
    recall_list = []
    f1_list = []

    for cls in range(n_classes):
        tp = cm[cls, cls]
        fp = np.sum(cm[:, cls]) - tp
        fn = np.sum(cm[cls, :]) - tp

        precision = tp / (tp + fp) if (tp + fp) != 0 else 0.0
        recall = tp / (tp + fn) if (tp + fn) != 0 else 0.0

        if precision + recall == 0:
            f1 = 0.0
        else:
            f1 = 2 * precision * recall / (precision + recall)

        precision_list.append(precision)
        recall_list.append(recall)
        f1_list.append(f1)

    return precision_list, recall_list, f1_list


def macro_precision_recall_f1(y_true, y_pred, n_classes=10):
    precision_list, recall_list, f1_list = precision_recall_f1_per_class(
        y_true,
        y_pred,
        n_classes
    )

    macro_precision = np.mean(precision_list)
    macro_recall = np.mean(recall_list)
    macro_f1 = np.mean(f1_list)

    return macro_precision, macro_recall, macro_f1


# ============================================================
# 7. Binary Linear SVM from Scratch
# ============================================================

class LinearSVMFromScratch:
    def __init__(
        self,
        learning_rate=0.01,
        lambda_param=0.0005,
        n_epochs=15,
        batch_size=512,
        lr_decay=0.95,
        patience=5,
        pos_weight_scale=1.0,
        verbose=False
    ):
        self.learning_rate = learning_rate
        self.lambda_param = lambda_param
        self.n_epochs = n_epochs
        self.batch_size = batch_size
        self.lr_decay = lr_decay
        self.patience = patience
        self.pos_weight_scale = pos_weight_scale
        self.verbose = verbose

        self.w = None
        self.b = 0.0

        self.train_losses = []
        self.val_losses = []

        self.best_w = None
        self.best_b = None
        self.best_val_loss = np.inf
        self.best_epoch = 0

    def _compute_class_weights(self, y):
        n_samples = len(y)

        n_pos = np.sum(y == 1)
        n_neg = np.sum(y == -1)

        weight_pos = n_samples / (2 * n_pos)
        weight_neg = n_samples / (2 * n_neg)

        weight_pos *= self.pos_weight_scale

        return weight_pos, weight_neg

    def _hinge_loss(self, X, y, weight_pos, weight_neg):
        scores = X @ self.w + self.b
        margins = y * scores

        sample_weights = np.where(y == 1, weight_pos, weight_neg)
        hinge = np.maximum(0, 1 - margins)

        loss = self.lambda_param * np.dot(self.w, self.w) + np.mean(sample_weights * hinge)

        return float(loss)

    def fit(self, X, y, X_val=None, y_val=None):
        n_samples, n_features = X.shape

        self.w = np.zeros(n_features, dtype=np.float32)
        self.b = 0.0

        weight_pos, weight_neg = self._compute_class_weights(y)

        current_lr = self.learning_rate
        no_improve_count = 0

        for epoch in range(self.n_epochs):
            indices = np.random.permutation(n_samples)

            X_shuffled = X[indices]
            y_shuffled = y[indices]

            for start in range(0, n_samples, self.batch_size):
                end = start + self.batch_size

                X_batch = X_shuffled[start:end]
                y_batch = y_shuffled[start:end]

                scores = X_batch @ self.w + self.b
                margins = y_batch * scores

                sample_weights = np.where(y_batch == 1, weight_pos, weight_neg)
                active = margins < 1

                if np.any(active):
                    X_active = X_batch[active]
                    y_active = y_batch[active]
                    w_active = sample_weights[active]

                    grad_w_hinge = -np.mean(
                        (w_active * y_active)[:, np.newaxis] * X_active,
                        axis=0
                    )

                    grad_b_hinge = -np.mean(w_active * y_active)
                else:
                    grad_w_hinge = np.zeros_like(self.w)
                    grad_b_hinge = 0.0

                grad_w = 2 * self.lambda_param * self.w + grad_w_hinge
                grad_b = grad_b_hinge

                self.w -= current_lr * grad_w
                self.b -= current_lr * grad_b

            train_loss = self._hinge_loss(X, y, weight_pos, weight_neg)
            self.train_losses.append(train_loss)

            msg = f"Epoch {epoch + 1}/{self.n_epochs}, Train Loss: {train_loss:.6f}"

            if X_val is not None and y_val is not None:
                val_loss = self._hinge_loss(X_val, y_val, weight_pos, weight_neg)
                self.val_losses.append(val_loss)

                msg += f", Val Loss: {val_loss:.6f}"

                if val_loss < self.best_val_loss:
                    self.best_val_loss = val_loss
                    self.best_w = self.w.copy()
                    self.best_b = self.b
                    self.best_epoch = epoch + 1
                    no_improve_count = 0
                else:
                    no_improve_count += 1

                if no_improve_count >= self.patience:
                    if self.verbose:
                        print(msg)
                        print("Early stopping triggered.")
                    break

            if self.verbose:
                print(msg)

            current_lr *= self.lr_decay

        if self.best_w is not None:
            self.w = self.best_w
            self.b = self.best_b

    def decision_function(self, X):
        return X @ self.w + self.b

    def predict(self, X):
        scores = self.decision_function(X)
        return np.where(scores >= 0, 1, -1)


# ============================================================
# 8. Multiclass One-vs-Rest SVM
# ============================================================

class MulticlassOVRSVMFromScratch:
    def __init__(
        self,
        n_classes=10,
        learning_rate=0.01,
        lambda_param=0.0005,
        n_epochs=15,
        batch_size=512,
        lr_decay=0.95,
        patience=5,
        pos_weight_scale=1.0,
        verbose=False
    ):
        self.n_classes = n_classes
        self.learning_rate = learning_rate
        self.lambda_param = lambda_param
        self.n_epochs = n_epochs
        self.batch_size = batch_size
        self.lr_decay = lr_decay
        self.patience = patience
        self.pos_weight_scale = pos_weight_scale
        self.verbose = verbose

        self.models = []
        self.avg_train_losses = []
        self.avg_val_losses = []

    def fit(self, X, y, X_val=None, y_val=None):
        self.models = []

        all_train_losses = []
        all_val_losses = []

        for cls in range(self.n_classes):
            print(f"\nTraining binary SVM for class {cls} vs rest")

            y_binary = np.where(y == cls, 1, -1)

            if y_val is not None:
                y_val_binary = np.where(y_val == cls, 1, -1)
            else:
                y_val_binary = None

            model = LinearSVMFromScratch(
                learning_rate=self.learning_rate,
                lambda_param=self.lambda_param,
                n_epochs=self.n_epochs,
                batch_size=self.batch_size,
                lr_decay=self.lr_decay,
                patience=self.patience,
                pos_weight_scale=self.pos_weight_scale,
                verbose=self.verbose
            )

            model.fit(
                X,
                y_binary,
                X_val=X_val,
                y_val=y_val_binary
            )

            self.models.append(model)
            all_train_losses.append(model.train_losses)
            all_val_losses.append(model.val_losses)

        self.avg_train_losses = self._average_curves(all_train_losses)
        self.avg_val_losses = self._average_curves(all_val_losses)

    def _average_curves(self, curves):
        valid_curves = [curve for curve in curves if len(curve) > 0]

        if len(valid_curves) == 0:
            return []

        min_len = min(len(curve) for curve in valid_curves)

        trimmed = np.array([curve[:min_len] for curve in valid_curves])

        return np.mean(trimmed, axis=0)

    def decision_function(self, X):
        scores = []

        for model in self.models:
            cls_score = model.decision_function(X)
            scores.append(cls_score)

        return np.column_stack(scores)

    def predict(self, X):
        scores = self.decision_function(X)
        return np.argmax(scores, axis=1)


# ============================================================
# 9. Stratified k-fold generator
# ============================================================

def stratified_k_fold_indices(y, k=3, random_state=42):
    np.random.seed(random_state)

    folds = [[] for _ in range(k)]
    classes = np.unique(y)

    for cls in classes:
        cls_indices = np.where(y == cls)[0]
        np.random.shuffle(cls_indices)

        split_indices = np.array_split(cls_indices, k)

        for fold_id in range(k):
            folds[fold_id].extend(split_indices[fold_id])

    folds = [np.array(fold) for fold in folds]

    return folds


# ============================================================
# 10. Cross-validation tuning
# ============================================================

def cross_validate_svm(
    X,
    y,
    param_grid,
    k=3,
    n_classes=10,
    random_state=42
):
    folds = stratified_k_fold_indices(y, k=k, random_state=random_state)

    results = []
    best_config = None
    best_score = -1.0

    for config in param_grid:
        print("\n=================================================")
        print("Testing config:", config)
        print("=================================================")

        fold_scores = []

        for fold_id in range(k):
            val_idx = folds[fold_id]
            train_idx = np.concatenate([
                folds[i] for i in range(k) if i != fold_id
            ])

            X_train_fold = X[train_idx]
            y_train_fold = y[train_idx]

            X_val_fold = X[val_idx]
            y_val_fold = y[val_idx]

            X_train_fold, X_val_fold = standardize_train_val(
                X_train_fold,
                X_val_fold
            )

            model = MulticlassOVRSVMFromScratch(
                n_classes=n_classes,
                learning_rate=config["learning_rate"],
                lambda_param=config["lambda_param"],
                n_epochs=config["n_epochs"],
                batch_size=config["batch_size"],
                lr_decay=config["lr_decay"],
                patience=config["patience"],
                pos_weight_scale=config["pos_weight_scale"],
                verbose=False
            )

            model.fit(
                X_train_fold,
                y_train_fold,
                X_val=X_val_fold,
                y_val=y_val_fold
            )

            y_val_pred = model.predict(X_val_fold)

            acc = accuracy_score_manual(y_val_fold, y_val_pred)
            _, _, macro_f1 = macro_precision_recall_f1(
                y_val_fold,
                y_val_pred,
                n_classes=n_classes
            )

            fold_scores.append(macro_f1)

            print(
                f"Fold {fold_id + 1}/{k} | "
                f"Accuracy: {acc:.4f} | "
                f"Macro F1: {macro_f1:.4f}"
            )

            del model
            del X_train_fold
            del X_val_fold
            gc.collect()

        avg_macro_f1 = np.mean(fold_scores)

        results.append({
            "learning_rate": config["learning_rate"],
            "lambda_param": config["lambda_param"],
            "n_epochs": config["n_epochs"],
            "batch_size": config["batch_size"],
            "lr_decay": config["lr_decay"],
            "patience": config["patience"],
            "pos_weight_scale": config["pos_weight_scale"],
            "avg_cv_macro_f1": avg_macro_f1
        })

        print("Average CV Macro F1:", avg_macro_f1)

        if avg_macro_f1 > best_score:
            best_score = avg_macro_f1
            best_config = config

    results_df = pd.DataFrame(results)

    return best_config, best_score, results_df


