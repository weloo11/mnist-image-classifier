def plot_learning_curves(model, output_path):
    plt.figure(figsize=(8, 5))

    if len(model.avg_train_losses) > 0:
        plt.plot(model.avg_train_losses, label="Average Training Loss")

    if len(model.avg_val_losses) > 0:
        plt.plot(model.avg_val_losses, label="Average Validation Loss")

    plt.xlabel("Epoch")
    plt.ylabel("Loss")
    plt.title("Learning Curves — Multiclass One-vs-Rest SVM")
    plt.legend()
    plt.grid(True)

    plt.savefig(output_path, dpi=300, bbox_inches="tight")
    plt.close()

    print(f"Saved learning curve to: {output_path}")


def plot_confusion_matrix_heatmap(cm, title, output_path):
    plt.figure(figsize=(10, 8))

    plt.imshow(cm)
    plt.title(title)
    plt.xlabel("Predicted Label")
    plt.ylabel("True Label")
    plt.colorbar()

    labels = np.arange(cm.shape[0])
    plt.xticks(labels, labels)
    plt.yticks(labels, labels)

    threshold = cm.max() / 2

    for i in range(cm.shape[0]):
        for j in range(cm.shape[1]):
            value = cm[i, j]
            text_color = "white" if value > threshold else "black"

            plt.text(
                j,
                i,
                str(value),
                ha="center",
                va="center",
                color=text_color,
                fontsize=9
            )

    plt.tight_layout()
    plt.savefig(output_path, dpi=300, bbox_inches="tight")
    plt.close()

    print(f"Saved confusion matrix heatmap to: {output_path}")


